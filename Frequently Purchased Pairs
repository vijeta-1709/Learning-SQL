SELECT 
    t1.product_id AS product_id_1,
    t2.product_id AS product_id_2,
    COUNT(*) AS pair_count
FROM transactions t1
JOIN transactions t2
    ON t1.transaction_id = t2.transaction_id
    AND t1.product_id < t2.product_id
GROUP BY 
    t1.product_id, 
    t2.product_id
ORDER BY 
    pair_count DESC,
    product_id_1,
    product_id_2;
